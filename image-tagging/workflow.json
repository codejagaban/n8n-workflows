              "type": "string"
            },
            {
              "id": "set-tags-1",
              "name": "tags",
              "value": "={{ $json.tags }}",
              "type": "array"
            },
            {
              "id": "set-cdn-1",
              "name": "cdnUrl",
              "value": "={{ $json.cdnUrl }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
