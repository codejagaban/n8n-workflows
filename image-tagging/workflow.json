    {
      "parameters": {
        "jsCode": "// Read Rekognition labels from appdata and keep only confident tags.\nconst CONFIDENCE_THRESHOLD = 80;\n\nconst file = $input.first().json;\nconst labels =\n  file?.appdata?.aws_rekognition_detect_labels?.data?.Labels || [];\n\nconst tags = labels\n  .filter((label) => label.Confidence >= CONFIDENCE_THRESHOLD)\n  .map((label) => label.Name);\n\nreturn [\n  {\n    json: {\n      uuid: file.uuid,\n      cdnUrl: `https://2ta6v1zvst.ucarecd.net/${file.uuid}/`,\n      tags,\n      tagCount: tags.length,\n    },\n  },\n];"
      },
